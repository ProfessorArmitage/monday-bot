# Monday Bot — Variables de entorno
# Copia este archivo como .env y rellena los valores
# cp .env.example .env

# ── Telegram ──────────────────────────────────────────────────
# Token del bot — obtenerlo de @BotFather en Telegram
TELEGRAM_TOKEN=your_telegram_bot_token_here

# ── Groq (Modelo de IA) ────────────────────────────────────────
# API Key de Groq — https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# ── Base de datos ──────────────────────────────────────────────
# PostgreSQL connection string
# En Railway se genera automáticamente al agregar el plugin PostgreSQL
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── Google OAuth 2.0 ──────────────────────────────────────────
# Crear en Google Cloud Console → APIs & Services → Credentials
# Tipo: Web application
# https://console.cloud.google.com
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ── URLs del servidor ──────────────────────────────────────────
# URL pública de tu deploy en Railway (sin slash final)
RAILWAY_PUBLIC_URL=https://your-project.up.railway.app

# URL del callback OAuth — debe coincidir exactamente con la
# configurada en Google Cloud Console → Authorized redirect URIs
CALLBACK_URL=https://your-project.up.railway.app/oauth/callback

# ── Servidor HTTP ──────────────────────────────────────────────
# Puerto interno (Railway lo asigna automáticamente, no cambiar)
PORT=8080

# ── Seguridad ──────────────────────────────────────────────────
# Clave de cifrado para tokens de Google en la base de datos
# Generar con: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# ⚠️  IMPORTANTE: guárdala en un lugar seguro. Si la pierdes, los usuarios
#     deberán reconectar su cuenta de Google.
ENCRYPTION_KEY=your_fernet_key_here

# ── Rate limiting (opcional — estos son los valores por defecto) ──
# Máximo de mensajes por ventana de tiempo
RATE_LIMIT_MESSAGES=20
# Ventana de tiempo en segundos
RATE_LIMIT_WINDOW=60
# Tiempo de bloqueo en segundos tras exceder el límite
RATE_LIMIT_COOLDOWN=300

# ── Límites de input (opcional) ───────────────────────────────
# Longitud máxima de mensaje de texto (caracteres)
MAX_MESSAGE_LENGTH=4000
# Tamaño máximo de audio en MB
MAX_VOICE_SIZE_MB=10
